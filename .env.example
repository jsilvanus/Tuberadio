# =============================================================================
# Tuberadio — environment variable reference
#
# Copy this file to .env and adjust the values for your deployment.
# docker-compose.yml reads .env automatically.
# =============================================================================

# ---------------------------------------------------------------------------
# Host port bindings (Docker only)
# The internal container ports are always 1935 (RTMP) and 8080 (HTTP).
# Change the host-side ports here if those ports are already in use.
# ---------------------------------------------------------------------------
RTMP_PORT=1935
HTTP_PORT=8080

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------

# Port the Node.js API process listens on inside the container.
# You don't normally need to change this.
PORT=3000

# How long (ms) after the last HLS manifest update before the stream is
# considered "off air". Default: 30 000 (30 s).
STALE_MS=30000

# ---------------------------------------------------------------------------
# Public URLs — returned in the /api/status and /api/archive JSON responses.
# Set these to the publicly accessible URLs of your server so that the
# embeddable widget can reach the stream and archives from any domain.
# ---------------------------------------------------------------------------

# Full public URL (or path) of the live HLS manifest.
# If Tuberadio is behind a reverse proxy at https://radio.example.com, set:
#   HLS_STREAM_URL=https://radio.example.com/hls/stream.m3u8
HLS_STREAM_URL=/hls/stream.m3u8

# URL prefix used to build download links for archived recordings.
# Example: https://radio.example.com/archive
ARCHIVE_URL_PREFIX=/archive

# ---------------------------------------------------------------------------
# Filesystem paths (inside the container / on the host for bare-metal)
# ---------------------------------------------------------------------------

# Directory where nginx-rtmp writes HLS segments and the manifest.
HLS_DIR=/var/www/radio/hls

# Directory where FFmpeg writes timestamped MP3 archive files.
ARCHIVE_DIR=/var/www/radio/archive

# Directory where FFmpeg writes its per-session log files.
LOG_DIR=/var/log/tuberadio

# ---------------------------------------------------------------------------
# FFmpeg audio settings (on-publish.sh)
# ---------------------------------------------------------------------------

# Audio bitrate used for both the HLS stream and the MP3 archive.
AUDIO_BITRATE=128k

# Duration of each HLS segment in seconds.
HLS_TIME=4

# Number of segments kept in the rolling HLS playlist.
# Older segments are deleted automatically.
HLS_LIST_SIZE=10
