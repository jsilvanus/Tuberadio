# =============================================================================
# Tuberadio — environment variable reference
#
# Copy this file to .env and adjust the values for your deployment.
# docker-compose.yml reads .env automatically.
# =============================================================================

# ---------------------------------------------------------------------------
# Host port bindings (Docker only)
# The internal container ports are always 1935 (RTMP) and 8080 (HTTP).
# Change the host-side ports here if those ports are already in use.
# ---------------------------------------------------------------------------
RTMP_PORT=1935
HTTP_PORT=8080

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------

# Port the Node.js API process listens on inside the container.
# You don't normally need to change this.
PORT=3000

# How long (ms) after the last HLS manifest update before the stream is
# considered "off air". Default: 30 000 (30 s).
STALE_MS=30000

# ---------------------------------------------------------------------------
# Public URLs — returned in the /api/status and /api/archive JSON responses.
# Set these to the publicly accessible URLs of your server so that the
# embeddable widget can reach the stream and archives from any domain.
# ---------------------------------------------------------------------------

# Full public URL (or path) of the live HLS manifest.
# If Tuberadio is behind a reverse proxy at https://radio.example.com, set:
#   HLS_STREAM_URL=https://radio.example.com/hls/stream.m3u8
HLS_STREAM_URL=/hls/stream.m3u8

# URL prefix used to build download links for archived recordings.
# Example: https://radio.example.com/archive
ARCHIVE_URL_PREFIX=/archive

# ---------------------------------------------------------------------------
# Filesystem paths (inside the container / on the host for bare-metal)
# ---------------------------------------------------------------------------

# Directory where nginx-rtmp writes HLS segments and the manifest.
HLS_DIR=/var/www/radio/hls

# Directory where FFmpeg writes timestamped MP3 archive files.
ARCHIVE_DIR=/var/www/radio/archive

# Directory where aged-out recordings are moved (not publicly served).
HIDDEN_ARCHIVE_DIR=/var/www/radio/hidden_archive

# Directory where FFmpeg writes its per-session log files.
LOG_DIR=/var/log/tuberadio

# ---------------------------------------------------------------------------
# FFmpeg audio settings (on-publish.sh)
# ---------------------------------------------------------------------------

# Audio bitrate used for both the HLS stream and the MP3 archive.
AUDIO_BITRATE=128k

# Duration of each HLS segment in seconds.
HLS_TIME=4

# Number of segments kept in the rolling HLS playlist.
# Older segments are deleted automatically.
HLS_LIST_SIZE=10

# ---------------------------------------------------------------------------
# Archive ageing
# ---------------------------------------------------------------------------

# Move recordings from ARCHIVE_DIR to HIDDEN_ARCHIVE_DIR after this many days.
# The hidden archive is not publicly served by nginx, so the files are no
# longer available for download but are retained for backup/compliance.
# Set to 0 (or leave unset) to disable ageing.
ARCHIVE_AGE_DAYS=0

# Permanently delete recordings from HIDDEN_ARCHIVE_DIR after this many days.
# Set to 0 (or leave unset) to retain files in the hidden archive indefinitely.
HIDDEN_ARCHIVE_DELETE_DAYS=0

# ---------------------------------------------------------------------------
# Anonymous statistics
# ---------------------------------------------------------------------------

# Absolute path to the JSON file where aggregate play and session stats are
# stored. The directory will be created automatically if it doesn't exist.
# In Docker, this should point inside the radio-stats named volume.
STATS_FILE=/var/www/radio/stats/stats.json

# How many days of stream-session history to retain in stats.json.
# Older entries are pruned automatically on each new session.
STATS_SESSION_DAYS=90

# Optional bearer token that on-publish.sh and on-publish-done.sh send to
# POST /api/stats/session. If left empty, the endpoint is unprotected
# (acceptable for a private, single-host deployment).
STATS_SESSION_SECRET=

# Base URL of the Node.js API, as seen from inside the nginx container.
# In Docker Compose this must use the service name, not 127.0.0.1.
STATS_API_URL=http://api:3000

# ---------------------------------------------------------------------------
# Monthly statistics email
# ---------------------------------------------------------------------------

# Email provider to use for the end-of-month stats report.
# Supported values: sendgrid, mailgun
# Leave empty (or unset) to disable the monthly email entirely.
EMAIL_PROVIDER=

# Recipient and sender addresses for the monthly report.
EMAIL_TO=you@example.com
EMAIL_FROM=tuberadio@example.com

# SendGrid API key (required when EMAIL_PROVIDER=sendgrid).
SENDGRID_API_KEY=

# Mailgun API key and sending domain (required when EMAIL_PROVIDER=mailgun).
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.example.com
